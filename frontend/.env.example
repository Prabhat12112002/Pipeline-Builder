# Pipeline Builder — Frontend environment variables
# Copy this file to `.env` and adjust as needed.

# Base URL of the FastAPI backend.
# In development: http://localhost:8000
# In production:  https://api.your-domain.com
REACT_APP_API_URL=http://localhost:8000

# Disable the ESLint plugin during development to avoid build-blocking
# lint errors. Set to false if you want lint errors to fail the build.
DISABLE_ESLINT_PLUGIN=true
